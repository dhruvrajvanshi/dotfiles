[user]
	email = dhruv@rajv.dev
  name = Dhruv Rajvanshi

[core]
  excludesfile = ~/.gitignore
  pager = delta
# Put machine specific configs here
[include]
  path = local.gitconfig

# Note that the order of includes matters. Work gitconfig will override
# core.sshCommand typically for this directory, so this has to be included after the local.gitconfig include.
[includeIf "gitdir:~/projects/work/"]
  path = work.gitconfig

[push]
  autoSetupRemote = true
  default = simple

[pull]
  rebase = true

[merge]
  conflictstyle = zdiff3

[column]
  # Show lists in columns
  ui = auto

[branch]
  # make git branch show the most recent branch first
  sort = -committerdate

[diff]
  # Histogram handles moved code better
  algorithm = histogram
  # Highlight moved code in a different color
  colorMoved = plain
  # Header lines for diffs shows i for index, w for worktree and c for commit, instead of a/ and b/
  mnemonicPrefix = true

  # Handle renamed files better in diffs
  renames = true
  external = difft


[fetch]
	prune = true
	pruneTags = true
  all = true

[help]
  autocorrect = prompt

[commit]
  # Show diffs in the commit window
	verbose = true
[rerere]
	enabled = true
	autoupdate = true

[delta]
  side-by-side = true

[alias]
	st = !git status -sb && git log --oneline --abbrev-commit -5
  co = checkout
  ll = log --oneline --abbrev-commit -10
  br = "!git branch --sort=-committerdate --format='%(refname:short)' | head -10"
  search = !git rev-list --all | xargs git grep -F
  ca = commit --amend --no-edit
  c  = commit
  p  = push
